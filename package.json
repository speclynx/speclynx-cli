{
  "name": "@speclynx/cli",
  "version": "1.0.0",
  "description": "Messy API specs? Bring order from the command line — overlay, dereference, bundle, convert, and validate.",
  "keywords": [
    "cli",
    "api",
    "openapi",
    "asyncapi",
    "arazzo",
    "json-schema",
    "overlay",
    "dereference",
    "bundle",
    "convert",
    "validate",
    "specification",
    "swagger",
    "oas",
    "speclynx",
    "apidom"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "bin": {
    "speclynx": "./bin/speclynx.mjs"
  },
  "engines": {
    "node": ">=16.14.0"
  },
  "scripts": {
    "build": "npm run clean && npm run build:es && npm run build:cjs",
    "build:es": "cross-env BABEL_ENV=es babel src --out-dir src --extensions '.ts' --out-file-extension '.mjs'",
    "build:cjs": "cross-env BABEL_ENV=cjs babel src --out-dir src --extensions '.ts' --out-file-extension '.cjs'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf --glob 'src/**/*.mjs' 'src/**/*.cjs' 'test/**/*.mjs' ./dist",
    "typescript:check-types": "tsc --noEmit",
    "test": "npm run build:es && cross-env BABEL_ENV=es babel test --out-dir test --extensions '.ts' --out-file-extension '.mjs' && cross-env NODE_ENV=test mocha",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "files": [
    "bin/",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "LICENSE",
    "NOTICE",
    "package.json",
    "SECURITY.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/speclynx/speclynx-cli.git"
  },
  "author": "SpecLynx",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/speclynx/speclynx-cli/issues"
  },
  "homepage": "https://github.com/speclynx/speclynx-cli#readme",
  "dependencies": {
    "@babel/runtime-corejs3": "^7.28.4",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@babel/cli": "=7.28.6",
    "@babel/core": "=7.29.0",
    "@babel/helper-plugin-utils": "=7.27.1",
    "@babel/plugin-transform-runtime": "=7.29.0",
    "@babel/preset-env": "=7.29.2",
    "@babel/preset-typescript": "=7.28.5",
    "@commitlint/cli": "=20.5.0",
    "@commitlint/config-conventional": "=20.5.0",
    "@eslint/js": "^9.28.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "=10.0.10",
    "@types/node": "^25.2.3",
    "chai": "^6.2.1",
    "core-js": "=3.49.0",
    "cross-env": "=10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.0",
    "eslint-plugin-mocha": "^11.2.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.1.0",
    "husky": "=9.1.7",
    "lint-staged": "=16.4.0",
    "mocha": "=11.7.5",
    "prettier": "=3.8.2",
    "rimraf": "=6.1.3",
    "semantic-release": "^25.0.2",
    "typescript": "=6.0.2",
    "typescript-eslint": "^8.55.0"
  }
}
